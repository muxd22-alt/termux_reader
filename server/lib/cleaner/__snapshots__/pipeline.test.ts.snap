exports[`cleaning pipeline — snapshot tests > snapshot: en-docs (en) 1`] = `
"
        <section>
          <h2>Overview</h2>
          <p>Our API supports two authentication methods: OAuth 2.0 for user-level access and API keys for server-to-server communication. All API requests must be authenticated.</p>
        </section>

        <section>
          <h2>OAuth 2.0</h2>
          <p>OAuth 2.0 is the recommended authentication method for applications that access resources on behalf of users. We support the Authorization Code flow and the Client Credentials flow.</p>

          <h3>Authorization Code Flow</h3>
          <p>The authorization code flow is used when your application needs to access the API on behalf of a specific user. The flow involves redirecting the user to our authorization server, obtaining an authorization code, and exchanging it for an access token.</p>

          <pre><code>POST /oauth/token
Content-Type: application/x-www-form-urlencoded

grant_type=authorization_code&amp;
code=AUTH_CODE&amp;
redirect_uri=https://yourapp.com/callback&amp;
client_id=YOUR_CLIENT_ID&amp;
client_secret=YOUR_CLIENT_SECRET</code></pre>
        </section>

        <section>
          <h2>API Keys</h2>
          <p>API keys provide a simpler authentication mechanism for server-to-server integrations. Include your API key in the Authorization header of every request.</p>

          <pre><code>curl -H "Authorization: Bearer YOUR_API_KEY" \\
  https://api.example.com/v1/resources</code></pre>

          <table>
            <thead>
              <tr><th>Scope</th><th>Description</th><th>Access Level</th></tr>
            </thead>
            <tbody>
              <tr><td>read</td><td>Read-only access</td><td>Basic</td></tr>
              <tr><td>write</td><td>Read and write access</td><td>Standard</td></tr>
              <tr><td>admin</td><td>Full administrative access</td><td>Admin</td></tr>
            </tbody>
          </table>
        </section>
      "
`;

